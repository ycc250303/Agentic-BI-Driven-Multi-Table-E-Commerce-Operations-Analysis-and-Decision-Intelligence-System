        },
        {
          "name": "seller_id",
          "type": "VARCHAR(32)",
          "description": "卖家ID",
          "example": "seller_uuid"
        },
        {
          "name": "seller_state",
          "type": "VARCHAR(2)",
          "description": "卖家所在州",
          "example": "SP"
        },
        {
          "name": "total_gmv",
          "type": "DECIMAL",
          "description": "该卖家的总成交额",
          "unit": "巴西雷亚尔（BRL）"
        },
        {
          "name": "total_orders",
          "type": "BIGINT",
          "description": "该卖家的订单总数",
          "unit": "订单数"
        },
        {
          "name": "avg_review_score",
          "type": "DECIMAL",
          "description": "平均评分（1-5分）",
          "unit": "分数"
        }
      ],
      "use_cases": [
        "卖家绩效监控",
        "高差评卖家定位",
        "优秀卖家识别",
        "卖家分级管理"
      ],
      "example_questions": [
        "哪些卖家的差评率最高？",
        "Top 10卖家的销售额排名是什么？",
        "哪个州的卖家平均评分最高？",
        "找出销售额高但评分低的卖家"
      ],
      "sql_example": "SELECT * FROM mv_seller_perf WHERE year_month = '2017-12' ORDER BY total_gmv DESC LIMIT 20"
    },
    "mv_payment_dist": {
      "name": "mv_payment_dist",
      "description": "支付分布视图",
