  "agent_usage_guide": {
    "description": "供数据分析Agent使用的视图查询指南",
    "strategy": "当用户问题匹配到以下预聚合维度时，优先使用对应视图；若维度不匹配，则回退到基础表查询",
    "matching_rules": [
      {
        "dimension": "时间维度（月度）",
        "keywords": ["月", "月份", "月度", "monthly", "month"],
        "recommended_views": ["mv_monthly_sales", "mv_state_sales", "mv_category_sales", "mv_delivery_perf", "mv_seller_perf", "mv_payment_dist"]
      },
      {
        "dimension": "地理维度（州）",
        "keywords": ["州", "地区", "区域", "state", "region", "SP", "RJ", "MG"],
        "recommended_views": ["mv_state_sales", "mv_delivery_perf"]
      },
      {
        "dimension": "品类维度",
        "keywords": ["品类", "类别", "产品", "商品", "category", "product"],
        "recommended_views": ["mv_category_sales"]
      },
      {
        "dimension": "配送维度",
        "keywords": ["配送", "物流", "送达", "准时", "延迟", "delivery", "shipping", "late"],
        "recommended_views": ["mv_delivery_perf"]
      },
      {
        "dimension": "卖家维度",
        "keywords": ["卖家", "商家", "seller", "merchant"],
        "recommended_views": ["mv_seller_perf"]
      },
      {
        "dimension": "支付维度",
        "keywords": ["支付", "付款", "分期", "payment", "credit_card", "boleto"],
        "recommended_views": ["mv_payment_dist"]
      },
      {
        "dimension": "销售/GMV维度",
        "keywords": ["销售", "销售额", "GMV", "成交额", "revenue", "sales"],
        "recommended_views": ["mv_monthly_sales", "mv_state_sales", "mv_category_sales", "mv_seller_perf"]
      }
    ],
    "fallback_strategy": "当问题维度不在任何预聚合视图中时（如查询具体订单详情、客户行为路径等），Agent应回退到基础表进行JOIN查询"
  },
