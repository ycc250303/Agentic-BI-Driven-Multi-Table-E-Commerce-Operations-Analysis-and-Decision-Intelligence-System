{
  "views": {
    "mv_monthly_sales": {
      "name": "mv_monthly_sales",
      "description": "月度销售趋势视图",
      "granularity": "年-月",
      "business_purpose": "月度销售趋势、GMV环比增长分析",
      "fields": [
        {
          "name": "year_month",
          "type": "VARCHAR(7)",
          "description": "年月，格式YYYY-MM",
          "example": "2017-12"
        },
        {
          "name": "total_gmv",
          "type": "DECIMAL",
          "description": "总成交额（商品价格+运费）",
          "unit": "巴西雷亚尔（BRL）"
        },
        {
          "name": "total_orders",
          "type": "BIGINT",
          "description": "订单总数",
          "unit": "订单数"
        },
        {
          "name": "avg_basket",
          "type": "DECIMAL",
          "description": "平均客单价（GMV/订单数）",
          "unit": "巴西雷亚尔（BRL）"
        },
        {
          "name": "total_freight",
          "type": "DECIMAL",
          "description": "总运费金额",
          "unit": "巴西雷亚尔（BRL）"
        }
      ],
      "use_cases": [
        "月度销售趋势分析",
        "GMV环比增长计算",
        "年度销售对比",
        "平均客单价变化趋势",
        "运费成本分析"
      ],
      "example_questions": [
        "2017年每个月的销售额是多少？",
        "去年GMV的月度增长趋势如何？",
        "哪个季度的销售额最高？",
        "平均客单价有什么变化趋势？"
      ],
      "sql_example": "SELECT * FROM mv_monthly_sales WHERE year_month >= '2017-01' ORDER BY year_month"
    },
    "mv_state_sales": {
      "name": "mv_state_sales",
      "description": "各州销售情况视图",
      "granularity": "年-月-州",
      "business_purpose": "各州销售额排名、区域市场对比",
      "fields": [
        {
          "name": "year_month",
          "type": "VARCHAR(7)",
          "description": "年月，格式YYYY-MM",
          "example": "2017-12"
        },
        {
          "name": "customer_state",
          "type": "VARCHAR(2)",
          "description": "客户所在州（巴西州简称）",
          "example": "SP（圣保罗）"
        },
        {
          "name": "total_gmv",
          "type": "DECIMAL",
          "description": "该州的总成交额",
          "unit": "巴西雷亚尔（BRL）"
        },
        {
          "name": "total_orders",
          "type": "BIGINT",
          "description": "该州的订单总数",
          "unit": "订单数"
        },
        {
          "name": "unique_customers",
          "type": "BIGINT",
          "description": "该州的独立客户数",
          "unit": "客户数"
        }
      ],
      "use_cases": [
        "各州销售额排名",
        "区域市场对比",
        "重点市场识别",
        "州级市场渗透分析"
      ],
      "example_questions": [
        "2017年哪个州的销售额最高？",
        "圣保罗州（SP）的月度销售趋势如何？",
        "各州的订单量排名是什么？",
        "哪个州的客户最多？"
      ],
      "sql_example": "SELECT * FROM mv_state_sales WHERE year_month = '2017-12' ORDER BY total_gmv DESC LIMIT 10"
    },
    "mv_category_sales": {
      "name": "mv_category_sales",
      "description": "品类销售情况视图",
      "granularity": "年-月-品类",
      "business_purpose": "品类表现分析、识别下降品类",
      "fields": [
        {
          "name": "year_month",
          "type": "VARCHAR(7)",
          "description": "年月，格式YYYY-MM",
          "example": "2017-12"
        },
        {
          "name": "product_category_english",
          "type": "VARCHAR(255)",
          "description": "产品品类名称（英文）",
          "example": "electronics"
        },
        {
          "name": "total_gmv",
          "type": "DECIMAL",
          "description": "该品类的总销售额",
          "unit": "巴西雷亚尔（BRL）"
        },
        {
          "name": "total_orders",
          "type": "BIGINT",
          "description": "该品类的订单总数",
          "unit": "订单数"
        },
        {
          "name": "avg_price",
          "type": "DECIMAL",
          "description": "该品类的平均商品价格",
          "unit": "巴西雷亚尔（BRL）"
        }
      ],
      "use_cases": [
        "品类销售表现分析",
        "识别下降品类",
        "热门品类排名",
        "品类定价策略分析"
      ],
      "example_questions": [
        "哪些品类的销售额最高？",
        "2017年哪个品类的增长最快？",
        "哪些品类在下降？",
        "电子产品品类的平均价格是多少？"
      ],
      "sql_example": "SELECT * FROM mv_category_sales WHERE year_month >= '2017-01' ORDER BY year_month, total_gmv DESC"
    },
    "mv_delivery_perf": {
      "name": "mv_delivery_perf",
      "description": "配送绩效视图",
      "granularity": "年-月-州",
      "business_purpose": "配送延迟诊断、准时率分析",
      "fields": [
        {
          "name": "year_month",
          "type": "VARCHAR(7)",
          "description": "年月，格式YYYY-MM",
          "example": "2017-12"
        },
        {
          "name": "customer_state",
          "type": "VARCHAR(2)",
          "description": "客户所在州",
          "example": "SP"
        },
        {
          "name": "avg_delivery_days",
          "type": "DECIMAL",
          "description": "平均配送时长（从下单到签收）",
          "unit": "天"
        },
        {
          "name": "on_time_rate",
          "type": "DECIMAL",
          "description": "准时交付率（实际送达时间<=预计时间）",
          "unit": "比率（0-1）"
        },
        {
          "name": "delayed_orders",
          "type": "BIGINT",
          "description": "延迟订单数量",
          "unit": "订单数"
        }
      ],
      "use_cases": [
        "配送延迟诊断",
        "准时率分析",
        "区域配送质量对比",
        "物流供应商绩效评估"
      ],
      "example_questions": [
        "平台整体准时交付率是多少？",
        "哪些州延迟最严重？",
        "2017年各州的平均配送时长是多少？",
        "巴西东北部地区的配送准时率如何？"
      ],
      "sql_example": "SELECT * FROM mv_delivery_perf WHERE year_month = '2017-12' ORDER BY avg_delivery_days DESC"
    },
    "mv_seller_perf": {
      "name": "mv_seller_perf",
      "description": "卖家绩效视图",
